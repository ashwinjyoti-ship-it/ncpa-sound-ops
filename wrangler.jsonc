{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ncpa-sound-ops",
  "main": "dist/index.js",
  "compatibility_date": "2025-10-24",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./public"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ncpa-ops-db",
      "database_id": "e7f61ecc-994f-4a7e-84e3-21887a81e5d7"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "SHARED_PASSWORD": "ncpa2025"
  }
}
