{
  "name": "ncpa-sound-ops",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply ncpa-ops-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply ncpa-ops-db",
    "db:cleanup:prod": "wrangler d1 execute ncpa-ops-db --file=./migrations/0002_remove_unused_tables.sql",
    "db:seed:local": "wrangler d1 execute ncpa-ops-db --local --file=./seed.sql",
    "db:seed:prod": "wrangler d1 execute ncpa-ops-db --file=./seed.sql",
    "db:reset:local": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed:local",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.10.2"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "typescript": "^5.3.0",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
